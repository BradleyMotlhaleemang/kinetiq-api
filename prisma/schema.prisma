generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  displayName      String
  experienceLevel  String   @default("INTERMEDIATE")
  trainingAgeMths  Int      @default(0)
  bodyweightKg     Float?
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  gender                String?
  dateOfBirth           DateTime?
  goalMode              String?
  onboardingCompletedAt DateTime?
  notificationsEnabled  Boolean   @default(true)
  preferredTrainingTime String?
  mesocycles            Mesocycle[]
  workouts              Workout[]
  sessionReadiness   SessionReadiness[]
  weeklyFeedback     WeeklyFeedback[]
  performanceHistory PerformanceHistory[]
  progressionLogs    ProgressionLog[]
  prRecords          PRRecord[]
  plateauMarkers     PlateauMarker[]
  bioFeedback          BioFeedback[]
  exerciseSubstitutions ExerciseSubstitution[]
  bodyMetricLogs       BodyMetricLog[]
  notifications        NotificationLog[]
  fatigueSnapshots   FatigueSnapshot[]
}

model Exercise {
  id               String                     @id @default(cuid())
  name             String                     @unique
  primaryMuscle    String
  secondaryMuscles String[]
  movementPattern  String
  exerciseType     String
  isCompound       Boolean                    @default(true)
  metadata         ExerciseMetadata?
  substitutionPools SubstitutionPoolExercise[]
  sets              Set[]
  performanceHistory PerformanceHistory[]
  progressionLogs    ProgressionLog[]
  prRecords          PRRecord[]
  plateauMarkers     PlateauMarker[]
  originalSubstitutions  ExerciseSubstitution[] @relation("OriginalExercise")
  substituteSubstitutions ExerciseSubstitution[] @relation("SubstituteExercise")
}

model ExerciseMetadata {
  id                      String           @id @default(cuid())
  exerciseId              String           @unique
  exercise                Exercise         @relation(fields: [exerciseId], references: [id])
  fatigueScore            Float
  stabilityDemand         Float
  methodFatigueMultiplier Float
  equipmentProfileId      String
  equipmentProfile        EquipmentProfile @relation(fields: [equipmentProfileId], references: [id])
  executionProfileId      String
  executionProfile        ExecutionProfile @relation(fields: [executionProfileId], references: [id])
}

model EquipmentProfile {
  id                String             @id @default(cuid())
  name              String             @unique
  requiredEquipment String[]
  exercises         ExerciseMetadata[]
}

model ExecutionProfile {
  id          String             @id @default(cuid())
  zone        String             @unique
  description String
  rpeRange    String
  multiplier  Float
  exercises   ExerciseMetadata[]
}

model SubstitutionPool {
  id              String                     @id @default(cuid())
  name            String                     @unique
  primaryMuscle   String
  movementPattern String
  exercises       SubstitutionPoolExercise[]
}

model SubstitutionPoolExercise {
  id               String           @id @default(cuid())
  poolId           String
  pool             SubstitutionPool @relation(fields: [poolId], references: [id])
  exerciseId       String
  exercise         Exercise         @relation(fields: [exerciseId], references: [id])
  priority         Int
  suitableWhenPain String[]

  @@unique([poolId, exerciseId])
}

model WorkoutTemplate {
  id          String        @id @default(cuid())
  name        String        @unique
  splitType   String
  daysPerWeek Int
  splits      SplitConfig[]
}

model SplitConfig {
  id         String          @id @default(cuid())
  templateId String
  template   WorkoutTemplate @relation(fields: [templateId], references: [id])
  splitLabel String
  days       SplitDay[]
}

model SplitDay {
  id            String             @id @default(cuid())
  splitConfigId String
  splitConfig   SplitConfig        @relation(fields: [splitConfigId], references: [id])
  dayNumber     Int
  label         String
  exercises     SplitDayExercise[]
}

model SplitDayExercise {
  id          String   @id @default(cuid())
  splitDayId  String
  splitDay    SplitDay @relation(fields: [splitDayId], references: [id])
  exerciseId  String
  orderIndex  Int
  setsTarget  Int
  repRangeMin Int
  repRangeMax Int
}

model Mesocycle {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id])
  name           String
  status         String     @default("ACTIVE")
  currentWeek    Int        @default(1)
  totalWeeks     Int        @default(8)
  volumeTargets  Json
  templateId     String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  workouts       Workout[]
  weeklyFeedback     WeeklyFeedback[]
}

model Workout {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id])
  mesocycleId        String?
  mesocycle          Mesocycle?       @relation(fields: [mesocycleId], references: [id])
  splitDayLabel      String?
  status             String           @default("IN_PROGRESS")
  totalVolume        Float?
  totalSets          Int?
  durationMinutes    Int?
  completedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  sets               Set[]
  sessionReadiness   SessionReadiness?
  performanceHistory PerformanceHistory[]
  prRecords          PRRecord[]
  bioFeedback          BioFeedback?
}

model Set {
  id               String   @id @default(cuid())
  workoutId        String
  workout          Workout  @relation(fields: [workoutId], references: [id])
  exerciseId       String
  exercise         Exercise @relation(fields: [exerciseId], references: [id])
  setNumber        Int
  weight           Float
  reps             Int
  rpe              Float?
  e1rm             Float?
  effectiveReps    Float?
  fatigueCost      Float?
  stimulusScore    Float?
  isPR             Boolean  @default(false)
  prType           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SessionReadiness {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  workoutId           String?  @unique
  workout             Workout? @relation(fields: [workoutId], references: [id])
  sleepScore          Int
  stressScore         Int
  nutritionScore      Int
  motivationScore     Int
  muscleReadinessScore Int
  sessionReadiness    Float
  sessionMode         String
  createdAt           DateTime @default(now())
}

model WeeklyFeedback {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  mesocycleId        String?
  mesocycle          Mesocycle? @relation(fields: [mesocycleId], references: [id])
  weekNumber         Int
  motivationScore    Int
  fatiguePerception  Int
  performanceFeeling Int
  energyLevelAvg     Float?
  sleepQualityAvg    Float?
  stressLevelAvg     Float?
  jointPainMap       Json?
  notes              String?
  loggedAt           DateTime  @default(now())

  @@unique([userId, mesocycleId, weekNumber])
}

model KnowledgeEntry {
  id             String   @id @default(cuid())
  slug           String   @unique
  category       String
  title          String
  summary        String
  body           String
  relatedSlugs   Json?
  targetAudience String   @default("ALL")
  tags           Json?
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PerformanceHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  exerciseId  String
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  workoutId   String
  workout     Workout  @relation(fields: [workoutId], references: [id])
  bestE1rm    Float
  bestWeight  Float
  bestReps    Int
  totalVolume Float
  totalSets   Int
  date        DateTime

  @@unique([userId, exerciseId, date])
}

model ProgressionLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  exerciseId      String
  exercise        Exercise @relation(fields: [exerciseId], references: [id])
  action          String
  weightTarget    Float?
  reason          String
  contextSnapshot Json?
  loggedAt        DateTime @default(now())
}

model PRRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  exerciseId  String
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  prType      String
  value       Float
  achievedAt  DateTime @default(now())
  workoutId   String
  workout     Workout  @relation(fields: [workoutId], references: [id])
}

model PlateauMarker {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  reason     String
  createdAt  DateTime @default(now())
  resolved   Boolean  @default(false)
}

model BioFeedback {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  workoutId        String?  @unique
  workout          Workout? @relation(fields: [workoutId], references: [id])
  sorenessLog      Json
  jointPainLog     Json
  energyLevel      Int
  strengthRating   Int
  muscleFeel       Int
  sleepLastNight   Int
  overallWellbeing Int
  loggedAt         DateTime @default(now())
}

model ExerciseSubstitution {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  originalExerciseId String
  originalExercise   Exercise @relation("OriginalExercise", fields: [originalExerciseId], references: [id])
  substituteExerciseId String
  substituteExercise   Exercise @relation("SubstituteExercise", fields: [substituteExerciseId], references: [id])
  jointAffected      String
  painScoreAtSwap    Float
  status             String   @default("ACTIVE")
  phase              Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model BodyMetricLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  weightKg      Float
  bodyFatPercent Float?
  trend         String?
  rollingAvg7d  Float?
  loggedAt      DateTime @default(now())
}

model NotificationLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  type            String
  deliveryChannel String   @default("IN_APP")
  payload         Json?
  isRead          Boolean  @default(false)
  readAt          DateTime?
  createdAt       DateTime @default(now())

}
model FatigueSnapshot {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  snapshotAt         DateTime @default(now())
  sfl24h             Float
  sfl48h             Float
  sfl72h             Float
  sfl7d              Float
  cnsLoadScore       Float
  metabolicLoadScore Float
  muscleFatigueMap   Json
  jointStressMap     Json
}