generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  displayName      String
  experienceLevel  String   @default("INTERMEDIATE")
  trainingAgeMths  Int      @default(0)
  bodyweightKg     Float?
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  gender                String?
  dateOfBirth           DateTime?
  goalMode              String?
  onboardingCompletedAt DateTime?
  notificationsEnabled  Boolean   @default(true)
  preferredTrainingTime String?
  mesocycles            Mesocycle[]
  workouts              Workout[]
}

model Exercise {
  id               String                     @id @default(cuid())
  name             String                     @unique
  primaryMuscle    String
  secondaryMuscles String[]
  movementPattern  String
  exerciseType     String
  isCompound       Boolean                    @default(true)
  metadata         ExerciseMetadata?
  substitutionPools SubstitutionPoolExercise[]
  sets              Set[]
}

model ExerciseMetadata {
  id                      String           @id @default(cuid())
  exerciseId              String           @unique
  exercise                Exercise         @relation(fields: [exerciseId], references: [id])
  fatigueScore            Float
  stabilityDemand         Float
  methodFatigueMultiplier Float
  equipmentProfileId      String
  equipmentProfile        EquipmentProfile @relation(fields: [equipmentProfileId], references: [id])
  executionProfileId      String
  executionProfile        ExecutionProfile @relation(fields: [executionProfileId], references: [id])
}

model EquipmentProfile {
  id                String             @id @default(cuid())
  name              String             @unique
  requiredEquipment String[]
  exercises         ExerciseMetadata[]
}

model ExecutionProfile {
  id          String             @id @default(cuid())
  zone        String             @unique
  description String
  rpeRange    String
  multiplier  Float
  exercises   ExerciseMetadata[]
}

model SubstitutionPool {
  id              String                     @id @default(cuid())
  name            String                     @unique
  primaryMuscle   String
  movementPattern String
  exercises       SubstitutionPoolExercise[]
}

model SubstitutionPoolExercise {
  id               String           @id @default(cuid())
  poolId           String
  pool             SubstitutionPool @relation(fields: [poolId], references: [id])
  exerciseId       String
  exercise         Exercise         @relation(fields: [exerciseId], references: [id])
  priority         Int
  suitableWhenPain String[]

  @@unique([poolId, exerciseId])
}

model WorkoutTemplate {
  id          String        @id @default(cuid())
  name        String        @unique
  splitType   String
  daysPerWeek Int
  splits      SplitConfig[]
}

model SplitConfig {
  id         String          @id @default(cuid())
  templateId String
  template   WorkoutTemplate @relation(fields: [templateId], references: [id])
  splitLabel String
  days       SplitDay[]
}

model SplitDay {
  id            String             @id @default(cuid())
  splitConfigId String
  splitConfig   SplitConfig        @relation(fields: [splitConfigId], references: [id])
  dayNumber     Int
  label         String
  exercises     SplitDayExercise[]
}

model SplitDayExercise {
  id          String   @id @default(cuid())
  splitDayId  String
  splitDay    SplitDay @relation(fields: [splitDayId], references: [id])
  exerciseId  String
  orderIndex  Int
  setsTarget  Int
  repRangeMin Int
  repRangeMax Int
}

model Mesocycle {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id])
  name           String
  status         String     @default("ACTIVE")
  currentWeek    Int        @default(1)
  totalWeeks     Int        @default(8)
  volumeTargets  Json
  templateId     String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  workouts       Workout[]
}

model Workout {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id])
  mesocycleId        String?
  mesocycle          Mesocycle?       @relation(fields: [mesocycleId], references: [id])
  splitDayLabel      String?
  status             String           @default("IN_PROGRESS")
  totalVolume        Float?
  totalSets          Int?
  durationMinutes    Int?
  completedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  sets               Set[]
}

model Set {
  id               String   @id @default(cuid())
  workoutId        String
  workout          Workout  @relation(fields: [workoutId], references: [id])
  exerciseId       String
  exercise         Exercise @relation(fields: [exerciseId], references: [id])
  setNumber        Int
  weight           Float
  reps             Int
  rpe              Float?
  e1rm             Float?
  effectiveReps    Float?
  fatigueCost      Float?
  stimulusScore    Float?
  isPR             Boolean  @default(false)
  prType           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}